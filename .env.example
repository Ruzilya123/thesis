# PostgreSQL
POSTGRES_DB=doubleb_shop
POSTGRES_USER=doubleb
POSTGRES_PASSWORD=change-me-strong-password
# Локально (Poetry / npm run dev):
POSTGRES_HOST=localhost
# В Docker-стенде:
# POSTGRES_HOST=db
POSTGRES_PORT=5432

DB_ENGINE=postgresql

# Django
SECRET_KEY=change-me-in-production-use-long-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,185.240.102.123

# CORS (через запятую)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://185.240.102.123

# Frontend build (URL API для браузера)
VITE_API_URL=http://185.240.102.123/api

# Порты полного локального стенда (docker-compose.full.yml)
API_PORT=8000
FRONTEND_PORT=3000
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@doubleb.local
PGADMIN_DEFAULT_PASSWORD=admin
